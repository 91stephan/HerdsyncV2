# =============================================================
# HerdSync V2 — Government Server Environment Variables
# Copy to .env and fill in all values before running
# docker compose up -d
# NEVER commit .env to version control
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_strong_password_min_32_chars
AUTHENTICATOR_PASSWORD=change_this_authenticator_password

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=your-super-secret-jwt-token-at-least-32-chars-long
JWT_EXPIRY=3600

# Generate with: node -e "const jwt=require('jsonwebtoken');console.log(jwt.sign({role:'anon'},process.env.JWT_SECRET,{expiresIn:'10y'}))"
ANON_KEY=your-anon-key-here
SERVICE_ROLE_KEY=your-service-role-key-here

# ── URLs ──────────────────────────────────────────────────────
# External URL of the API gateway (Kong)
API_EXTERNAL_URL=http://your-server-ip:8000
SITE_URL=http://your-server-ip:3000
ADDITIONAL_REDIRECT_URLS=

# ── Realtime ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
REALTIME_ENC_KEY=your-realtime-enc-key-here
SECRET_KEY_BASE=your-secret-key-base-here

# ── SMTP (Ministry email server) ──────────────────────────────
SMTP_HOST=smtp.gov.ls
SMTP_PORT=587
SMTP_USER=noreply@agriculture.gov.ls
SMTP_PASS=your-smtp-password
